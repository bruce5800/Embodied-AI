<mujoco model="so_arm100">
    <compiler angle="degree" meshdir="robots_meshes/"/>
    <option gravity="0 0 -9.8" timestep="0.002" integrator="implicitfast"/>

    <!-- 定义材质和网格 -->
    <asset>
        <mesh name="a_mesh" file="AA.stl" scale="0.002 0.002 0.002"/>
        <mesh name="b_mesh" file="BB.stl" scale="0.002 0.002 0.002"/>
        <mesh name="c_mesh" file="CC.stl" scale="0.002 0.002 0.002"/>
        <mesh name="d_mesh" file="DD.stl" scale="0.002 0.002 0.002"/>
        <mesh name="e_mesh" file="EE.stl" scale="0.002 0.002 0.002"/>
        <mesh name="f_mesh" file="FF.stl" scale="0.002 0.002 0.002"/>
        <mesh name="g_mesh" file="GG.stl" scale="0.002 0.002 0.002"/>

        <!-- 夹爪手指材质 -->
        <material name="gripper_mat" rgba="0.3 0.3 0.3 1" specular="0.5" shininess="0.5"/>
    </asset>

    <!-- 默认设置 -->
    <default>
        <joint armature="5" damping="500"/>
        <position inheritrange="1" kv="100"/>
        <geom rgba="0.5 1 0.5 1" contype="1" conaffinity="1"
              solimp="0.95 0.99 0.001" solref="0.004 1.0"/>

        <!-- 夹爪手指的默认碰撞参数 -->
        <default class="gripper_finger">
            <geom contype="1" conaffinity="1" condim="4"
                  friction="1.5 0.05 0.01"
                  solimp="0.95 0.99 0.001" solref="0.004 1.0"
                  material="gripper_mat" mass="0.005"/>
        </default>
    </default>

    <!-- 世界坐标系 -->
    <worldbody>
        <!-- 基座 -->
        <body name="base" pos="0 0 0">
            <geom name="base_geom" type="mesh" mesh="a_mesh" mass="0.05" contype="0" conaffinity="0"/>

            <!-- link1: 腰部旋转 -->
            <body name="link1" pos="0 0 0">
                <joint name="joint1" type="hinge" axis="0 0 1" range="-100 100" pos="0 0 0"/>
                <geom name="link1_geom" type="mesh" mesh="b_mesh" mass="0.1"/>

                <!-- link2: 肩部俯仰 -->
                <body name="link2" pos="0 0 0">
                    <joint name="joint2" type="hinge" axis="0 1 0" range="-100 100" pos="-0.02548 0 0.188"/>
                    <geom name="link2_geom" type="mesh" mesh="c_mesh" mass="0.1"/>

                    <!-- link3: 肘部俯仰 -->
                    <body name="link3" pos="0 0 0">
                        <joint name="joint3" type="hinge" axis="0 1 0" range="-100 100" pos="-0.02548 0 0.422"/>
                        <geom name="link3_geom" type="mesh" mesh="d_mesh" mass="0.1"/>

                        <!-- link4: 腕部俯仰 -->
                        <body name="link4" pos="0 0 0">
                            <joint name="joint4" type="hinge" axis="0 1 0" range="-100 100" pos="-0.02548 0 0.656"/>
                            <geom name="link4_geom" type="mesh" mesh="e_mesh" mass="0.1"/>

                            <!-- link5: 腕部旋转 -->
                            <body name="link5" pos="0 0 0">
                                <joint name="joint5" type="hinge" axis="0 0 1" range="-180 180" pos="-0.02548 0.0018 0.792"/>
                                <geom name="link5_geom" type="mesh" mesh="f_mesh" mass="0.08"/>

                                <!-- link6: 末端执行器基座 -->
                                <body name="link6" pos="0 0 0">
                                    <joint name="joint6" type="hinge" axis="1 0 0" range="-50 90" pos="-0.02548 -0.02608 0.836"/>
                                    <geom name="link6_geom" type="mesh" mesh="g_mesh" mass="0.05"/>

                                    <!-- ========== 平行夹爪 ========== -->
                                    <!-- 左手指 -->
                                    <body name="finger_left" pos="-0.02548 -0.05 0.90">
                                        <joint name="finger_left_joint" type="slide" axis="0 1 0"
                                               range="-0.02 0.005" damping="50" armature="0.1"/>
                                        <geom class="gripper_finger" name="finger_left_geom"
                                              type="box" size="0.008 0.008 0.03" pos="0 0 0"/>
                                        <!-- 指尖（增加接触面积） -->
                                        <geom class="gripper_finger" name="finger_left_tip"
                                              type="box" size="0.012 0.004 0.015" pos="0 -0.01 -0.02"/>
                                    </body>

                                    <!-- 右手指 -->
                                    <body name="finger_right" pos="-0.02548 -0.05 0.90">
                                        <joint name="finger_right_joint" type="slide" axis="0 -1 0"
                                               range="-0.02 0.005" damping="50" armature="0.1"/>
                                        <geom class="gripper_finger" name="finger_right_geom"
                                              type="box" size="0.008 0.008 0.03" pos="0 0 0"/>
                                        <!-- 指尖 -->
                                        <geom class="gripper_finger" name="finger_right_tip"
                                              type="box" size="0.012 0.004 0.015" pos="0 0.01 -0.02"/>
                                    </body>

                                    <!-- 末端执行器参考点（用于 IK 目标） -->
                                    <site name="end_effector" pos="-0.02548 -0.05 0.87" size="0.005" rgba="1 0 0 0.5"/>

                                </body>
                            </body>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <!-- 执行器 -->
    <actuator>
        <!-- 6 个关节 -->
        <position name="joint1_actuator" joint="joint1" kp="2000" kv="200"/>
        <position name="joint2_actuator" joint="joint2" kp="2000" kv="200"/>
        <position name="joint3_actuator" joint="joint3" kp="1500" kv="150"/>
        <position name="joint4_actuator" joint="joint4" kp="1000" kv="100"/>
        <position name="joint5_actuator" joint="joint5" kp="800"  kv="80"/>
        <position name="joint6_actuator" joint="joint6" kp="800"  kv="80"/>
        <!-- 夹爪：两个手指联动 -->
        <position name="gripper_left_actuator"  joint="finger_left_joint"  kp="500" kv="100"/>
        <position name="gripper_right_actuator" joint="finger_right_joint" kp="500" kv="100"/>
    </actuator>

    <!-- 传感器（用于检测抓取力） -->
    <sensor>
        <touch name="finger_left_touch"  site="end_effector"/>
    </sensor>
</mujoco>
